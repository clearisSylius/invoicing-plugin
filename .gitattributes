# Normalize line endings — everything text uses LF in the repo, regardless of OS.
# Without this, files committed from Windows ship with CRLF and break PSR-12 (ECS
# fails with LineEndingFixer on every file).
* text=auto eol=lf

# Explicit text — keep LF even when Git's auto-detection is uncertain.
*.php  text eol=lf diff=php
*.xml  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.twig text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.neon text eol=lf
*.dist text eol=lf
Makefile text eol=lf

# Binaries — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.xlsx binary
*.xls  binary
*.docx binary
*.zip  binary
*.gz   binary
*.tar  binary

# Files excluded from the Composer tarball (development-only).
/.docker             export-ignore
/.editorconfig       export-ignore
/.gitattributes      export-ignore
/.github             export-ignore
/behat.yml.dist      export-ignore
/compose.yml         export-ignore
/compose.override.dist.yml export-ignore
/docker-compose.yml  export-ignore
/docs                export-ignore
/ecs.php             export-ignore
/etc                 export-ignore
/features            export-ignore
/Makefile            export-ignore
/node_modules        export-ignore
/phpspec.yml.dist    export-ignore
/phpstan.neon        export-ignore
/phpunit.xml.dist    export-ignore
/psalm.xml           export-ignore
/symfony.lock        export-ignore
/tests               export-ignore
/PUBLISH_AUDIT.md    export-ignore
