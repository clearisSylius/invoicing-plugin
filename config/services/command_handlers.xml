<?xml version="1.0" encoding="UTF-8" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <!--
            Los handlers llevan `#[AsMessageHandler]`, pero ese atributo SOLO
            convierte un servicio existente en handler de Messenger; no hace que
            la clase se registre como servicio. Como nuestro `services.xml` no
            tiene un `<prototype>` que escanee `src/`, hay que declararlos uno
            a uno aquí — sin eso, al despachar `RegeneratePdf`/`CreateInvoice`/
            `RectifyInvoice` Messenger lanza "No handler for message".
        -->

        <defaults autowire="true" autoconfigure="true" public="false" />

        <service id="ClearisSylius\InvoicingPlugin\CommandHandler\CreateInvoiceHandler" />
        <service id="ClearisSylius\InvoicingPlugin\CommandHandler\RectifyInvoiceHandler" />
        <service id="ClearisSylius\InvoicingPlugin\CommandHandler\RegeneratePdfHandler" />
    </services>

</container>
