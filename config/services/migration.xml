<?xml version="1.0" encoding="UTF-8" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false" />

        <service id="ClearisSylius\InvoicingPlugin\Migration\LegacyDetector" />
        <service id="ClearisSylius\InvoicingPlugin\Migration\LegacyInvoiceImporter" />
        <service id="ClearisSylius\InvoicingPlugin\Migration\Command\ImportFromOfficialCommand">
            <tag name="console.command" />
        </service>
    </services>

</container>
