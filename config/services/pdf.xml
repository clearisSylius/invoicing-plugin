<?xml version="1.0" encoding="UTF-8" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false" />

        <service id="ClearisSylius\InvoicingPlugin\Pdf\DompdfRenderer">
            <argument>%clearis_sylius_invoicing.pdf.paper_size%</argument>
            <argument>%clearis_sylius_invoicing.pdf.orientation%</argument>
            <argument>%kernel.project_dir%</argument>
        </service>
        <service id="ClearisSylius\InvoicingPlugin\Pdf\PdfRendererInterface"
                 alias="ClearisSylius\InvoicingPlugin\Pdf\DompdfRenderer" />

        <service id="ClearisSylius\InvoicingPlugin\Storage\FilesystemPdfStorage">
            <argument>%clearis_sylius_invoicing.pdf.storage_directory%</argument>
        </service>
        <service id="ClearisSylius\InvoicingPlugin\Storage\PdfStorageInterface"
                 alias="ClearisSylius\InvoicingPlugin\Storage\FilesystemPdfStorage" />

        <service id="ClearisSylius\InvoicingPlugin\Pdf\InvoicePdfGenerator">
            <argument type="service" id="twig" />
            <argument type="service" id="ClearisSylius\InvoicingPlugin\Pdf\PdfRendererInterface" />
            <argument type="service" id="ClearisSylius\InvoicingPlugin\Storage\PdfStorageInterface" />
            <argument type="service" id="ClearisSylius\InvoicingPlugin\Doctrine\ORM\InvoiceTemplateRepository" />
            <argument type="service" id="ClearisSylius\InvoicingPlugin\Doctrine\ORM\ChannelInvoicingSettingsRepository" />
            <argument>%clearis_sylius_invoicing.pdf.default_template_code%</argument>
        </service>
        <service id="ClearisSylius\InvoicingPlugin\Pdf\InvoicePdfGeneratorInterface"
                 alias="ClearisSylius\InvoicingPlugin\Pdf\InvoicePdfGenerator" />
    </services>

</container>
