{% extends '@ClearisSyliusInvoicingPlugin/admin/_layout/page.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% set title = ('clearis.ui.rectify.title'|trans) ~ ' ' ~ invoice.number %}

{% block page_title %}
    <i class="ti ti-arrow-back-up me-1"></i>
    {{ 'clearis.ui.rectify.title'|trans }} {{ invoice.number }}
{% endblock %}

{% block page_body %}
    <div class="alert alert-warning d-flex align-items-center" role="alert">
        <i class="ti ti-alert-triangle me-2"></i>
        <div>{{ 'clearis.ui.rectify.warning'|trans }}</div>
    </div>

    {{ form_start(form) }}
        {{ form_widget(form) }}
        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-arrow-back-up me-1"></i> {{ 'clearis.ui.rectify.submit'|trans }}
            </button>
            <a href="{{ path('clearis_invoicing_admin_invoice_show', {id: invoice.id}) }}" class="btn btn-outline-secondary">
                {{ 'clearis.ui.cancel'|trans }}
            </a>
        </div>
    {{ form_end(form) }}
{% endblock %}
